{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Buddio",
  "version": "1.0.0-rc9",
  "identifier": "com.buddio.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build && powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/fetch-vbcable.ps1",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Buddio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "devtools": false,
        "dragDropEnabled": true
      },
      {
        "label": "mini",
        "title": "Buddio Mini",
        "url": "index.html?window=mini",
        "width": 360,
        "height": 560,
        "minWidth": 320,
        "minHeight": 160,
        "decorations": false,
        "resizable": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "devtools": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/samples/sound-test-sample.wav",
      "resources/vbcable/pack/"
    ],
    "licenseFile": "../LICENSE",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English", "PortugueseBR"],
        "displayLanguageSelector": true,
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
