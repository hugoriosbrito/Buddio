{
  "name": "buddio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "gen:bindings": "bun run scripts/gen-bindings.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:build": "bun run build && tauri build --debug --no-bundle",
    "e2e": "wdio run e2e/wdio.conf.mjs",
    "e2e:routeerror": "wdio run e2e/wdio.routeerror.conf.mjs",
    "e2e:all": "bun run e2e && bun run e2e:routeerror"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@wdio/cli": "7",
    "@wdio/local-runner": "7",
    "@wdio/mocha-framework": "7",
    "@wdio/spec-reporter": "7",
    "@zip.js/zip.js": "2.8.26",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.10",
    "webdriverio": "7"
  },
  "trustedDependencies": [
    "edgedriver"
  ],
  "overrides": {
    "https-proxy-agent": "^7.0.6"
  }
}
